---
import { getAbsoluteLocaleUrl } from 'astro:i18n';
import config from '../data/config.json';
import { useTranslations } from '../i18n';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = config.meta.title,
  description = config.meta.description,
} = Astro.props;

const lang = Astro.currentLocale ?? 'en';
const t = useTranslations(lang);
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />

    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- hreflang -->
    <link rel="alternate" hreflang="en" href={getAbsoluteLocaleUrl('en', '/')} />
    <link rel="alternate" hreflang="it" href={getAbsoluteLocaleUrl('it', '/')} />
    <link rel="alternate" hreflang="x-default" href={getAbsoluteLocaleUrl('en', '/')} />

    <!-- Preload fonts -->
    <link rel="preload" href={`${import.meta.env.BASE_URL}fonts/SpaceGrotesk-Variable.woff2`} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={`${import.meta.env.BASE_URL}fonts/Inter-Variable.woff2`} as="font" type="font/woff2" crossorigin />

    <title>{title}</title>
    <!-- Anti-flash: apply saved theme before first paint -->
    <script is:inline>
      try {
        const t = localStorage.getItem('portfolio-theme');
        if (t) document.documentElement.setAttribute('data-theme', t);
      } catch(e) {}
    </script>
  </head>
  <body>
    <a href="#main-content" class="skip-to-content">{t('skip')}</a>
    <slot />
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
  @import '../styles/animations.css';
</style>
