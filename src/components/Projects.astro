---
import SectionHeading from './SectionHeading.astro';
import ProjectCard from './ProjectCard.astro';
import ScrollReveal from './ScrollReveal.astro';
import { projects } from '../data/projects';
import { useTranslations } from '../i18n';

const t = useTranslations(Astro.currentLocale ?? 'en');
---

<section class="section projects" id="projects">
  <div class="container">
    <ScrollReveal>
      <SectionHeading number="03">
        <Fragment slot="title">{t('sections.projects')}</Fragment>
      </SectionHeading>
    </ScrollReveal>

    <div class="projects__grid reveal-stagger">
      {projects.map((project, i) => (
        <ProjectCard project={project} description={t(`projects.${i}.description`)} />
      ))}
    </div>
  </div>
</section>

<style>
  .projects__grid {
    display: grid;
    gap: 1.5rem;
    grid-template-columns: 1fr;
  }

  @media (min-width: 1024px) {
    .projects__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
