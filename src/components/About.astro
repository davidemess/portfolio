---
import SectionHeading from './SectionHeading.astro';
import ScrollReveal from './ScrollReveal.astro';
import config from '../data/config.json';
import { en, it } from '../i18n';

const { terminal } = config.about;
const terminalJson = JSON.stringify(terminal, null, 2);
const { name, role } = config.personal;
const jsonLines = terminalJson.split('\n');

const lang = Astro.currentLocale ?? 'en';
const bio = lang === 'it' ? it.about.bio : en.about.bio;
---

<section class="section about" id="about">
  <div class="container">
    <ScrollReveal>
      <SectionHeading number="01" title="whoami" />
    </ScrollReveal>

    <ScrollReveal>
      <div class="tmux">
        <div class="tmux__panes">

          <!-- ── TOP-LEFT: whoami ── -->
          <div class="tmux__pane tmux__pane--whoami">
            <div class="tmux__pane-header">
              <span class="tmux__pane-label">whoami</span>
            </div>
            <div class="tmux__pane-body">
              <div class="tmux__stack">
                <div class="tmux__ghost" aria-hidden="true">
                  <div class="tmux__cmd-line">
                    <span class="tmux__prompt">$</span>
                    <span class="tmux__cmd-text">whoami</span>
                  </div>
                  <p class="tmux__out tmux__out--name">
                    <span class="tmux__prefix">&gt;&nbsp;</span>{name} — {role}
                  </p>
                </div>
                <div id="output-whoami"></div>
              </div>
              <div class="tmux__cursor-line tmux__cursor-line--hidden" id="cursor-whoami">
                <span class="tmux__prompt">$</span>
                <span class="tmux__cursor">█</span>
              </div>
            </div>
          </div>

          <!-- ── BOTTOM-LEFT: cat bio.txt ── -->
          <div class="tmux__pane tmux__pane--bio">
            <div class="tmux__pane-header">
              <span class="tmux__pane-label">cat bio.txt</span>
            </div>
            <div class="tmux__pane-body">
              <div class="tmux__stack">
                <div class="tmux__ghost" aria-hidden="true">
                  <div class="tmux__cmd-line">
                    <span class="tmux__prompt">$</span>
                    <span class="tmux__cmd-text">cat bio.txt</span>
                  </div>
                  {bio.map((p) => (
                    <p class="tmux__out tmux__out--bio">{p}</p>
                  ))}
                </div>
                <div id="output-bio"></div>
              </div>
              <div class="tmux__cursor-line tmux__cursor-line--hidden" id="cursor-bio">
                <span class="tmux__prompt">$</span>
                <span class="tmux__cursor">█</span>
              </div>
            </div>
          </div>

          <!-- ── RIGHT (spans both rows): cat status.json ── -->
          <div class="tmux__pane tmux__pane--json">
            <div class="tmux__pane-header">
              <span class="tmux__pane-label">cat status.json</span>
            </div>
            <div class="tmux__pane-body">
              <div class="tmux__stack">
                <div class="tmux__ghost" aria-hidden="true">
                  <div class="tmux__cmd-line">
                    <span class="tmux__prompt">$</span>
                    <span class="tmux__cmd-text">cat status.json</span>
                  </div>
                  {jsonLines.map((l) => (
                    <p class="tmux__out tmux__out--json">
                      <span class="tmux__prefix">&gt;&nbsp;</span>{l}
                    </p>
                  ))}
                </div>
                <div id="output-json"></div>
              </div>
              <div class="tmux__cursor-line tmux__cursor-line--hidden" id="cursor-json">
                <span class="tmux__prompt">$</span>
                <span class="tmux__cursor">█</span>
              </div>
            </div>
          </div>

        </div>

        <!-- ── Status bar ── -->
        <div class="tmux__statusbar">
          <div class="tmux__statusbar-left">
            <span class="tmux__session">davide-messori</span>
            <span class="tmux__win tmux__win--active">0&nbsp;profile.sh&nbsp;●</span>
          </div>
          <div class="tmux__statusbar-right">
            <span id="tmux-clock"></span>
          </div>
        </div>
      </div>
    </ScrollReveal>
  </div>
</section>

<script define:vars={{ name, role, bio, terminalJson }}>
  const CHAR_DELAY = 40;
  const OUTPUT_DELAY = 80;
  const STEP_DELAY = 320;

  const jsonLines = terminalJson.split('\n');

  function wait(ms) {
    return new Promise(resolve => setTimeout(resolve, ms));
  }

  function createOutputLine(text, type) {
    const p = document.createElement('p');
    p.className = `tmux__out tmux__out--${type}`;
    if (type === 'bio') {
      p.textContent = text;
    } else {
      const prefix = document.createElement('span');
      prefix.className = 'tmux__prefix';
      prefix.textContent = '> ';
      p.appendChild(prefix);
      p.appendChild(document.createTextNode(text));
    }
    return p;
  }

  async function typeCommand(el, command) {
    const cmdLine = document.createElement('div');
    cmdLine.className = 'tmux__cmd-line';
    const prompt = document.createElement('span');
    prompt.className = 'tmux__prompt';
    prompt.textContent = '$';
    const cmdText = document.createElement('span');
    cmdText.className = 'tmux__cmd-text';
    cmdLine.appendChild(prompt);
    cmdLine.appendChild(cmdText);
    el.appendChild(cmdLine);
    for (const char of command) {
      cmdText.textContent += char;
      await wait(CHAR_DELAY);
    }
  }

  async function showOutput(el, lines) {
    for (const { text, type } of lines) {
      await wait(OUTPUT_DELAY);
      el.appendChild(createOutputLine(text, type));
    }
  }

  function showCursor(id) {
    const el = document.getElementById(id);
    if (el) el.classList.remove('tmux__cursor-line--hidden');
  }

  async function runAnimation() {
    const outWhoami = document.getElementById('output-whoami');
    const outBio    = document.getElementById('output-bio');
    const outJson   = document.getElementById('output-json');

    await typeCommand(outWhoami, 'whoami');
    await showOutput(outWhoami, [{ text: `${name} — ${role}`, type: 'name' }]);
    showCursor('cursor-whoami');

    await wait(STEP_DELAY);

    await typeCommand(outBio, 'cat bio.txt');
    await showOutput(outBio, bio.map(p => ({ text: p, type: 'bio' })));
    showCursor('cursor-bio');

    await wait(STEP_DELAY);

    await typeCommand(outJson, 'cat status.json');
    await showOutput(outJson, jsonLines.map(l => ({ text: l, type: 'json' })));
    showCursor('cursor-json');
  }

  // Live clock
  function updateClock() {
    const el = document.getElementById('tmux-clock');
    if (!el) return;
    const now = new Date();
    const days   = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];
    const months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
    const hh = String(now.getHours()).padStart(2, '0');
    const mm = String(now.getMinutes()).padStart(2, '0');
    el.textContent = `${days[now.getDay()]} ${now.getDate()} ${months[now.getMonth()]}  ${hh}:${mm}`;
  }
  updateClock();
  setInterval(updateClock, 60000);

  // Scroll-triggered
  const trigger = document.querySelector('.tmux');
  const observer = new IntersectionObserver(
    ([entry]) => {
      if (entry.isIntersecting) {
        observer.disconnect();
        runAnimation();
      }
    },
    { threshold: 0.15 }
  );
  if (trigger) observer.observe(trigger);
</script>

<style>
  /* ── Shell ── */
  .tmux {
    background-color: #0e0e0e;
    border: 1px solid #2a2a2a;
    border-radius: var(--radius-md);
    overflow: hidden;
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    box-shadow: 0 12px 48px rgba(0, 0, 0, 0.5);
  }

  .tmux__panes {
    display: grid;
    grid-template-columns: 55fr 45fr;
    grid-template-areas:
      "whoami json"
      "bio    json";
  }

  .tmux__pane--whoami { grid-area: whoami; border-right: 1px solid #2a2a2a; }
  .tmux__pane--bio    { grid-area: bio;    border-right: 1px solid #2a2a2a; }
  .tmux__pane--json   { grid-area: json; }

  .tmux__pane-header {
    display: flex;
    align-items: center;
    height: 1.5rem;
    padding: 0 0.75rem;
    gap: 0.5rem;
    border-bottom: 1px solid #2a2a2a;
  }

  .tmux__pane-header::after {
    content: '';
    flex: 1;
    height: 1px;
    background: #2a2a2a;
  }

  .tmux__pane-label {
    font-size: 0.65rem;
    color: #555;
    white-space: nowrap;
    letter-spacing: 0.05em;
  }

  .tmux__pane-body {
    padding: 0.875rem 1rem;
    line-height: 1.7;
    color: var(--color-text-primary);
  }

  .tmux__stack { display: grid; grid-template-areas: 'layer'; }
  .tmux__ghost, .tmux__stack > div { grid-area: layer; }
  .tmux__ghost { opacity: 0; pointer-events: none; user-select: none; }

  .tmux__cursor-line {
    display: flex;
    gap: 0.5rem;
    margin-top: 0.35rem;
  }

  .tmux__cursor-line--hidden { visibility: hidden; }

  .tmux__prompt { color: var(--color-accent); font-weight: 700; user-select: none; }
  .tmux__cursor { color: var(--color-accent); animation: blink 1s step-end infinite; }

  .tmux__statusbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 1.75rem;
    background-color: #111;
    border-top: 1px solid #2a2a2a;
    font-size: var(--text-xs);
    overflow: hidden;
  }

  .tmux__statusbar-left { display: flex; align-items: stretch; height: 100%; }

  .tmux__session {
    display: flex;
    align-items: center;
    padding: 0 0.875rem;
    background-color: var(--color-accent);
    color: #000;
    font-weight: 700;
    letter-spacing: 0.03em;
  }

  .tmux__win {
    display: flex;
    align-items: center;
    padding: 0 0.875rem;
    color: var(--color-text-secondary);
  }

  .tmux__win--active { color: var(--color-text-heading); background-color: #1a1a1a; }
  .tmux__statusbar-right { padding: 0 0.875rem; color: var(--color-text-secondary); }

  @media (max-width: 767px) {
    .tmux__panes {
      grid-template-columns: 1fr;
      grid-template-areas: "whoami" "bio" "json";
    }
    .tmux__pane--whoami, .tmux__pane--bio { border-right: none; }
  }

  :global(.tmux__cmd-line)  { display: flex; gap: 0.5rem; align-items: baseline; }
  :global(.tmux__cmd-text)  { color: var(--color-text-heading); font-weight: 600; }
  :global(.tmux__prefix)    { color: var(--color-accent); opacity: 0.4; user-select: none; }

  :global(.tmux__out--name) {
    color: var(--color-text-heading);
    font-size: var(--text-base);
    font-weight: 700;
    padding-left: 1rem;
    margin-top: 0.25rem;
  }

  :global(.tmux__out--bio) {
    color: var(--color-text-primary);
    font-size: var(--text-sm);
    line-height: 1.9;
    padding: 0.15rem 0.875rem;
    margin-left: 0.125rem;
    margin-top: 0.1rem;
    border-left: 2px solid #2a2a2a;
    word-break: break-word;
  }

  :global(.tmux__out--json) {
    color: var(--color-accent);
    font-size: var(--text-xs);
    padding-left: 1rem;
    line-height: 1.75;
    opacity: 0.7;
    margin-top: 0.05rem;
    white-space: pre-wrap;
  }
</style>
