---
import config from '../data/config.json';

const base = import.meta.env.BASE_URL;

const links = [
  { label: 'About',    href: '#about' },
  { label: 'Skills',   href: '#skills' },
  { label: 'Projects', href: '#projects' },
  { label: 'Career',   href: '#career' },
  { label: 'Contact',  href: '#contact' },
];
---

<header class="nav" id="nav">
  <nav class="nav__inner container" aria-label="Navigazione principale">
    <a href="#" class="nav__logo" aria-label="Home">
      <span class="nav__logo-bracket">[</span>
      <span class="nav__logo-text">{config.personal.logoText}</span>
      <span class="nav__logo-bracket">]</span>
    </a>

    <ul class="nav__links" id="nav-links" role="list">
      {links.map((link) => (
        <li>
          <a href={link.href} class="nav__link">{link.label}</a>
        </li>
      ))}
      <li>
        <button class="nav__link nav__link--palette" data-palette-open aria-haspopup="dialog">
          palette
        </button>
      </li>
    </ul>

    <div class="nav__controls">
      <div class="nav__themes" role="group" aria-label="Color theme">
        <button class="nav__theme-btn" data-theme="" aria-label="Default theme" title="Default"></button>
        <button class="nav__theme-btn" data-theme="terminal" aria-label="Terminal Dark theme" title="Terminal Dark"></button>
        <button class="nav__theme-btn" data-theme="deep-space" aria-label="Deep Space theme" title="Deep Space"></button>
        <button class="nav__theme-btn" data-theme="matrix" aria-label="Matrix Green theme" title="Matrix Green"></button>
        <button class="nav__theme-btn" data-theme="glitch" aria-label="Glitch Mode theme" title="Glitch Mode"></button>
      </div>

      <button
        class="nav__hamburger"
        id="nav-toggle"
        aria-label="Apri menu"
        aria-expanded="false"
        aria-controls="nav-links"
      >
        <span class="nav__hamburger-line"></span>
        <span class="nav__hamburger-line"></span>
        <span class="nav__hamburger-line"></span>
      </button>
    </div>
  </nav>
</header>

<style>
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    padding: 1rem 0;
    transition: background-color var(--transition-base), backdrop-filter var(--transition-base);
  }

  .nav.scrolled {
    background-color: color-mix(in srgb, var(--color-bg-primary) 85%, transparent);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--color-border);
  }

  .nav__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .nav__logo {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: 700;
    letter-spacing: 0.1em;
    text-decoration: none;
    display: flex;
    gap: 2px;
  }

  .nav__logo-bracket {
    color: var(--color-accent);
  }

  .nav__logo-text {
    color: var(--color-text-heading);
  }

  .nav__links {
    display: none;
    gap: 2rem;
  }

  .nav__link {
    font-family: var(--font-display);
    font-size: var(--text-xs);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: color var(--transition-fast);
    position: relative;
  }

  .nav__link::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 0;
    width: 0;
    height: 1px;
    background-color: var(--color-accent);
    transition: width var(--transition-base);
  }

  .nav__link:hover {
    color: var(--color-accent);
  }

  .nav__link:hover::after {
    width: 100%;
  }

  .nav__link--palette {
    font-family: var(--font-mono);
    color: var(--color-accent);
    opacity: 0.5;
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
  }
  .nav__link--palette::before {
    content: '//';
    margin-right: 0.3em;
    opacity: 0.6;
  }
  .nav__link--palette:hover {
    opacity: 1;
    color: var(--color-accent);
  }

  /* Hamburger */
  .nav__hamburger {
    display: flex;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
  }

  .nav__hamburger-line {
    display: block;
    width: 24px;
    height: 2px;
    background-color: var(--color-text-primary);
    transition: transform var(--transition-base), opacity var(--transition-base);
  }

  .nav__hamburger[aria-expanded='true'] .nav__hamburger-line:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }

  .nav__hamburger[aria-expanded='true'] .nav__hamburger-line:nth-child(2) {
    opacity: 0;
  }

  .nav__hamburger[aria-expanded='true'] .nav__hamburger-line:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  /* Mobile menu open */
  .nav__links.open {
    display: flex;
    flex-direction: column;
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    background-color: color-mix(in srgb, var(--color-bg-primary) 95%, transparent);
    backdrop-filter: blur(12px);
    padding: 2rem;
    gap: 1.5rem;
    border-bottom: 1px solid var(--color-border);
  }

  .nav__links.open .nav__link {
    font-size: var(--text-base);
  }

  /* ── Controls: theme switcher + hamburger ── */
  .nav__controls {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .nav__themes {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .nav__theme-btn {
    width: 16px;
    height: 16px;
    border-radius: 50%;
    border: none;
    padding: 0;
    cursor: pointer;
    opacity: 0.5;
    flex-shrink: 0;
    transition: opacity var(--transition-fast), transform var(--transition-fast), box-shadow var(--transition-fast);
  }

  /* default: solid accent green */
  .nav__theme-btn[data-theme=""]           { background-color: #00FF41; }
  /* TERMINAL_DARK: fg:#7fff6a acc:#bf5fff */
  .nav__theme-btn[data-theme="terminal"]   { background: linear-gradient(135deg, #7fff6a 50%, #bf5fff 50%); }
  /* DEEP_SPACE: fg:#e0b3ff acc:#7fff6a */
  .nav__theme-btn[data-theme="deep-space"] { background: linear-gradient(135deg, #e0b3ff 50%, #7fff6a 50%); }
  /* MATRIX_GRN: fg:#b8ffb0 acc:#9c27b0 */
  .nav__theme-btn[data-theme="matrix"]     { background: linear-gradient(135deg, #b8ffb0 50%, #9c27b0 50%); }
  /* GLITCH_MODE: fg:#bf5fff acc:#52c44a */
  .nav__theme-btn[data-theme="glitch"]     { background: linear-gradient(135deg, #bf5fff 50%, #52c44a 50%); }

  .nav__theme-btn:hover {
    opacity: 0.85;
    transform: scale(1.15);
  }

  /* doppio ring: prima shadow "scava" il bg, la seconda disegna il bordo colorato */
  .nav__theme-btn.active {
    opacity: 1;
    box-shadow:
      0 0 0 2px var(--color-bg-primary),
      0 0 0 4px var(--color-accent);
  }

  @media (min-width: 1024px) {
    .nav__links {
      display: flex;
    }

    .nav__hamburger {
      display: none;
    }
  }
</style>

<script>
  function initNav() {
    const nav = document.getElementById('nav');
    const toggle = document.getElementById('nav-toggle');
    const links = document.getElementById('nav-links');

    if (!nav || !toggle || !links) return;

    // Scroll detection
    const onScroll = () => {
      nav.classList.toggle('scrolled', window.scrollY > 50);
    };
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();

    // Hamburger toggle
    toggle.addEventListener('click', () => {
      const expanded = toggle.getAttribute('aria-expanded') === 'true';
      toggle.setAttribute('aria-expanded', String(!expanded));
      toggle.setAttribute('aria-label', expanded ? 'Apri menu' : 'Chiudi menu');
      links.classList.toggle('open');
    });

    // Close menu on link click
    links.querySelectorAll('a').forEach((a) => {
      a.addEventListener('click', () => {
        toggle.setAttribute('aria-expanded', 'false');
        toggle.setAttribute('aria-label', 'Apri menu');
        links.classList.remove('open');
      });
    });
  }

  // ── Theme switcher ──
  function initTheme() {
    const saved = localStorage.getItem('portfolio-theme') ?? '';
    applyTheme(saved, false);
  }

  function applyTheme(theme, save = true) {
    if (theme) {
      document.documentElement.setAttribute('data-theme', theme);
    } else {
      document.documentElement.removeAttribute('data-theme');
    }
    if (save) localStorage.setItem('portfolio-theme', theme);

    document.querySelectorAll('.nav__theme-btn').forEach(btn => {
      const match = (btn as HTMLElement).dataset.theme === theme;
      btn.classList.toggle('active', match);
      btn.setAttribute('aria-pressed', String(match));
    });
  }

  document.querySelectorAll('.nav__theme-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      applyTheme((btn as HTMLElement).dataset.theme ?? '');
    });
  });

  initTheme();
  initNav();
  document.addEventListener('astro:after-swap', () => { initNav(); initTheme(); });
</script>
