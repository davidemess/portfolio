---
import { getRelativeLocaleUrl } from 'astro:i18n';
import config from '../data/config.json';
import { useTranslations } from '../i18n';

const lang = Astro.currentLocale ?? 'en';
const t = useTranslations(lang);
const isIT = lang === 'it';

const links = [
  { key: 'nav.about',    href: '#about' },
  { key: 'nav.skills',   href: '#skills' },
  { key: 'nav.projects', href: '#projects' },
  { key: 'nav.career',   href: '#career' },
  { key: 'nav.contact',  href: '#contact' },
];
---

<header class="nav" id="nav">
  <nav class="nav__inner container" aria-label="Navigazione principale">
    <a href="#" class="nav__logo" aria-label="Home">
      <span class="nav__logo-bracket">[</span>
      <span class="nav__logo-text">{config.personal.logoText}</span>
      <span class="nav__logo-bracket">]</span>
    </a>

    <ul class="nav__links" id="nav-links" role="list">
      {links.map((link) => (
        <li>
          <a href={link.href} class="nav__link">{t(link.key)}</a>
        </li>
      ))}
      <li>
        <button class="nav__link nav__link--palette" data-palette-open aria-haspopup="dialog">
          palette
        </button>
      </li>
    </ul>

    <div class="nav__controls">
      <div class="nav__lang" role="group" aria-label="Language / Lingua">
        <a href={getRelativeLocaleUrl('en', '/')} class="nav__lang-btn" aria-current={!isIT ? 'true' : undefined}>EN</a>
        <a href={getRelativeLocaleUrl('it', '/')} class="nav__lang-btn" aria-current={isIT ? 'true' : undefined}>IT</a>
      </div>

      <div class="nav__themes" role="group" aria-label="Color theme">
        <button class="nav__theme-btn" data-theme="" aria-label="Default theme" title="Default"></button>
        <button class="nav__theme-btn" data-theme="terminal" aria-label="Terminal Dark theme" title="Terminal Dark"></button>
        <button class="nav__theme-btn" data-theme="deep-space" aria-label="Deep Space theme" title="Deep Space"></button>
        <button class="nav__theme-btn" data-theme="matrix" aria-label="Matrix Green theme" title="Matrix Green"></button>
        <button class="nav__theme-btn" data-theme="glitch" aria-label="Glitch Mode theme" title="Glitch Mode"></button>
      </div>

      <button
        class="nav__hamburger"
        id="nav-toggle"
        aria-label={t('nav.openMenu')}
        aria-expanded="false"
        aria-controls="nav-links"
      >
        <span class="nav__hamburger-line"></span>
        <span class="nav__hamburger-line"></span>
        <span class="nav__hamburger-line"></span>
      </button>
    </div>
  </nav>
</header>

<style>
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    padding: 1rem 0;
    transition: background-color var(--transition-base), backdrop-filter var(--transition-base);
  }

  .nav.scrolled {
    background-color: color-mix(in srgb, var(--color-bg-primary) 85%, transparent);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--color-border);
  }

  .nav__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .nav__logo {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: 700;
    letter-spacing: 0.1em;
    text-decoration: none;
    display: flex;
    gap: 2px;
  }

  .nav__logo-bracket { color: var(--color-accent); }
  .nav__logo-text    { color: var(--color-text-heading); }

  .nav__links {
    display: none;
    gap: 2rem;
  }

  .nav__link {
    font-family: var(--font-display);
    font-size: var(--text-xs);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: color var(--transition-fast);
    position: relative;
  }

  .nav__link::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 0;
    width: 0;
    height: 1px;
    background-color: var(--color-accent);
    transition: width var(--transition-base);
  }

  .nav__link:hover         { color: var(--color-accent); }
  .nav__link:hover::after  { width: 100%; }

  .nav__link--palette {
    font-family: var(--font-mono);
    color: var(--color-accent);
    opacity: 0.5;
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
  }
  .nav__link--palette::before { content: '//'; margin-right: 0.3em; opacity: 0.6; }
  .nav__link--palette:hover   { opacity: 1; color: var(--color-accent); }

  /* Hamburger */
  .nav__hamburger {
    display: flex;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
  }

  .nav__hamburger-line {
    display: block;
    width: 24px;
    height: 2px;
    background-color: var(--color-text-primary);
    transition: transform var(--transition-base), opacity var(--transition-base);
  }

  .nav__hamburger[aria-expanded='true'] .nav__hamburger-line:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .nav__hamburger[aria-expanded='true'] .nav__hamburger-line:nth-child(2) { opacity: 0; }
  .nav__hamburger[aria-expanded='true'] .nav__hamburger-line:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  /* Mobile menu open */
  .nav__links.open {
    display: flex;
    flex-direction: column;
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    background-color: color-mix(in srgb, var(--color-bg-primary) 95%, transparent);
    backdrop-filter: blur(12px);
    padding: 2rem;
    gap: 1.5rem;
    border-bottom: 1px solid var(--color-border);
  }

  .nav__links.open .nav__link { font-size: var(--text-base); }

  /* ── Controls ── */
  .nav__controls { display: flex; align-items: center; gap: 1rem; }

  /* Language switcher */
  .nav__lang { display: flex; align-items: center; gap: 2px; }

  .nav__lang-btn {
    font-family: var(--font-mono);
    font-size: 9px;
    letter-spacing: 0.15em;
    background: none;
    border: 1px solid transparent;
    color: var(--color-text-secondary);
    padding: 2px 6px;
    border-radius: var(--radius-sm);
    cursor: pointer;
    transition: color var(--transition-fast), border-color var(--transition-fast);
    text-decoration: none;
  }

  .nav__lang-btn[aria-current='true'] {
    color: var(--color-accent);
    border-color: color-mix(in srgb, var(--color-accent) 40%, transparent);
  }

  /* Theme switcher */
  .nav__themes { display: flex; align-items: center; gap: 10px; }

  .nav__theme-btn {
    width: 16px;
    height: 16px;
    border-radius: 50%;
    border: none;
    padding: 0;
    cursor: pointer;
    opacity: 0.5;
    flex-shrink: 0;
    transition: opacity var(--transition-fast), transform var(--transition-fast), box-shadow var(--transition-fast);
  }

  .nav__theme-btn[data-theme=""]           { background-color: #00FF41; }
  .nav__theme-btn[data-theme="terminal"]   { background: linear-gradient(135deg, #7fff6a 50%, #bf5fff 50%); }
  .nav__theme-btn[data-theme="deep-space"] { background: linear-gradient(135deg, #e0b3ff 50%, #7fff6a 50%); }
  .nav__theme-btn[data-theme="matrix"]     { background: linear-gradient(135deg, #b8ffb0 50%, #9c27b0 50%); }
  .nav__theme-btn[data-theme="glitch"]     { background: linear-gradient(135deg, #bf5fff 50%, #52c44a 50%); }

  .nav__theme-btn:hover { opacity: 0.85; transform: scale(1.15); }

  .nav__theme-btn.active {
    opacity: 1;
    box-shadow: 0 0 0 2px var(--color-bg-primary), 0 0 0 4px var(--color-accent);
  }

  @media (min-width: 1024px) {
    .nav__links    { display: flex; }
    .nav__hamburger { display: none; }
  }
</style>

<script>
  import { en, it } from '../i18n/index.ts';

  function getMenuLabels() {
    const lang = document.documentElement.lang;
    const trans = lang === 'it' ? it : en;
    return { open: trans.nav.openMenu, close: trans.nav.closeMenu };
  }

  // ── Nav (scroll + hamburger) ──
  function initNav() {
    const nav    = document.getElementById('nav');
    const toggle = document.getElementById('nav-toggle');
    const links  = document.getElementById('nav-links');
    if (!nav || !toggle || !links) return;

    const onScroll = () => nav.classList.toggle('scrolled', window.scrollY > 50);
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();

    toggle.addEventListener('click', () => {
      const expanded = toggle.getAttribute('aria-expanded') === 'true';
      const labels = getMenuLabels();
      toggle.setAttribute('aria-expanded', String(!expanded));
      toggle.setAttribute('aria-label', expanded ? labels.open : labels.close);
      links.classList.toggle('open');
    });

    links.querySelectorAll('a').forEach(a => {
      a.addEventListener('click', () => {
        const labels = getMenuLabels();
        toggle.setAttribute('aria-expanded', 'false');
        toggle.setAttribute('aria-label', labels.open);
        links.classList.remove('open');
      });
    });
  }

  // ── Theme switcher ──
  function applyTheme(theme: string, save = true) {
    if (theme) document.documentElement.setAttribute('data-theme', theme);
    else        document.documentElement.removeAttribute('data-theme');
    if (save) localStorage.setItem('portfolio-theme', theme);

    document.querySelectorAll('.nav__theme-btn').forEach(btn => {
      const match = (btn as HTMLElement).dataset.theme === theme;
      btn.classList.toggle('active', match);
      btn.setAttribute('aria-pressed', String(match));
    });
  }

  function initTheme() {
    applyTheme(localStorage.getItem('portfolio-theme') ?? '', false);
  }

  document.querySelectorAll('.nav__theme-btn').forEach(btn => {
    btn.addEventListener('click', () => applyTheme((btn as HTMLElement).dataset.theme ?? ''));
  });

  initTheme();
  initNav();
  document.addEventListener('astro:after-swap', () => { initTheme(); initNav(); });
</script>
